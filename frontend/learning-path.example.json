              "minInclusive": true,
              "maxInclusive": true
            }
          }
        ]
      }
    },
    {
      "id": "edge-math1-advanced",
      "sourceNodeId": "node-math-1",
      "targetNodeId": "node-math-2-advanced",
      "label": "Passed assessment",
